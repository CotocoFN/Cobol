           SELECT VIP-CLIFOR
              ASSIGN TO "VIP-CLIFOR.DAT"
              ORGANIZATION INDEXED
              ACCESS MODE DYNAMIC
              LOCK MODE AUTOMATIC
              RECORD KEY CLIFOR-CHAVE
              ALTERNATE RECORD KEY CLIFOR-CHAVE-EXT-1 = CLIFOR-NM-CLIFOR
              WITH DUPLICATES
              FILE STATUS FS-VIP-CLIFOR.